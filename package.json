{
  "name": "bw-productions-ops",
  "version": "1.0.0",
  "description": "B&W Productions Internal Operations Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=bw-productions-db --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name bw-productions",
    "db:migrate:local": "wrangler d1 migrations apply bw-productions-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply bw-productions-db",
    "db:seed": "wrangler d1 execute bw-productions-db --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "hono": "^4.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.78.0"
  }
}
