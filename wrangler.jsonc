{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bw-productions",
  "compatibility_date": "2024-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bw-productions-db",
      "database_id": "local-dev"
    }
  ]
}
